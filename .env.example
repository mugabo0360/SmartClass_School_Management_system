# SmartClass Environment Variables
# Copy this file to .env.local and fill in your actual values.
# NEVER commit real keys.

# ============================================================
# SUPABASE (free tier)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================================
# GOOGLE GEMINI AI (optional on free plan)
# ============================================================
GEMINI_API_KEY=

# AI free-tier controls (safe defaults)
# off: disable AI calls completely
# free: allow AI calls with strict limits and fallback content
AI_MODE=free
AI_FALLBACK_MODE=template
AI_MAX_REQUESTS_PER_MINUTE=20
AI_MAX_REQUESTS_PER_DAY=500

# ============================================================
# APP CONFIGURATION
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SmartClass
NEXT_PUBLIC_APP_VERSION=1.0.0
DEFAULT_REGION=UG

# ============================================================
# PAYMENT PROVIDERS (sandbox first)
# ============================================================
MTN_MOMO_ENVIRONMENT=sandbox
AIRTEL_ENVIRONMENT=sandbox

# ============================================================
# AUTH / SECURITY
# ============================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret